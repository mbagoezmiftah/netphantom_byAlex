<UserControl x:Class="NetPhantom.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
        <StackPanel MaxWidth="620" HorizontalAlignment="Left">

            <!-- ── Scanner Settings ── -->
            <TextBlock Text="扫描设置" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,12"/>
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>

                    <TextBox Margin="0,0,0,12"
                             materialDesign:HintAssist.Hint="默认扫描范围"
                             Text="{Binding DefaultScanRange, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="默认使用 ARP 扫描" VerticalAlignment="Center"/>
                        <ToggleButton DockPanel.Dock="Right" IsChecked="{Binding UseArpScan}"/>
                    </DockPanel>

                    <TextBox Margin="0,0,0,12"
                             materialDesign:HintAssist.Hint="扫描超时 (ms)"
                             Text="{Binding ScanTimeoutMs, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                    <TextBox materialDesign:HintAssist.Hint="最大并发数"
                             Text="{Binding MaxConcurrency, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- ── Spoofer Settings ── -->
            <TextBlock Text="欺骗设置" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,12"/>
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>

                    <TextBox Margin="0,0,0,12"
                             materialDesign:HintAssist.Hint="默认发送间隔 (ms)"
                             Text="{Binding SpoofIntervalMs, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="自动检测网关" VerticalAlignment="Center"/>
                        <ToggleButton DockPanel.Dock="Right" IsChecked="{Binding AutoDetectGateway}"/>
                    </DockPanel>

                    <DockPanel>
                        <TextBlock Text="开始欺骗前显示警告" VerticalAlignment="Center"/>
                        <ToggleButton DockPanel.Dock="Right" IsChecked="{Binding ConfirmBeforeSpoof}"/>
                    </DockPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- ── UI Settings ── -->
            <TextBlock Text="界面设置" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,12"/>
            <materialDesign:Card Padding="16" Margin="0,0,0,24">
                <DockPanel>
                    <TextBlock Text="显示日志面板" VerticalAlignment="Center"/>
                    <ToggleButton DockPanel.Dock="Right" IsChecked="{Binding ShowLogPanel}"/>
                </DockPanel>
            </materialDesign:Card>

            <!-- ── Actions ── -->
            <WrapPanel>
                <Button Command="{Binding SaveSettingsCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" VerticalAlignment="Center"/>
                        <TextBlock Text="保存设置" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding ResetDefaultsCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Restore" Width="18" Height="18" VerticalAlignment="Center"/>
                        <TextBlock Text="恢复默认" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>
            </WrapPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
