<UserControl x:Class="NetPhantom.Views.SpooferView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Config Card ── -->
        <materialDesign:Card Grid.Row="0" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- NIC -->
                <ComboBox Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,12,12"
                          materialDesign:HintAssist.Hint="选择网卡"
                          ItemsSource="{Binding Interfaces}"
                          SelectedItem="{Binding SelectedInterface}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          IsEnabled="{Binding IsSpoofing, Converter={StaticResource InverseBooleanConverter}}"/>

                <!-- Target IP -->
                <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,12,12"
                         materialDesign:HintAssist.Hint="目标 IP"
                         Text="{Binding TargetIp, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         IsEnabled="{Binding IsSpoofing, Converter={StaticResource InverseBooleanConverter}}"/>

                <!-- Target MAC -->
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,12,12"
                         materialDesign:HintAssist.Hint="目标 MAC"
                         Text="{Binding TargetMac, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         IsEnabled="{Binding IsSpoofing, Converter={StaticResource InverseBooleanConverter}}"/>

                <!-- Gateway IP -->
                <TextBox Grid.Row="2" Grid.Column="0" Margin="0,0,12,12"
                         materialDesign:HintAssist.Hint="网关 IP"
                         Text="{Binding GatewayIp, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         IsEnabled="{Binding IsSpoofing, Converter={StaticResource InverseBooleanConverter}}"/>

                <!-- Interval -->
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,12">
                    <TextBox Width="120"
                             materialDesign:HintAssist.Hint="间隔 (ms)"
                             Text="{Binding IntervalMs, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             IsEnabled="{Binding IsSpoofing, Converter={StaticResource InverseBooleanConverter}}"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="2"
                            VerticalAlignment="Center" Margin="8,0,0,0">

                    <Button Command="{Binding DetectGatewayCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,0,8"
                            IsEnabled="{Binding IsSpoofing, Converter={StaticResource InverseBooleanConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="RouterNetwork" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="自动检测网关" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding StartSpoofCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="0,0,0,8"
                            Background="#F44336"
                            IsEnabled="{Binding IsSpoofing, Converter={StaticResource InverseBooleanConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="LanPending" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="开始欺骗" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding StopSpoofCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            IsEnabled="{Binding IsSpoofing}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Stop" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="停止" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- ── Status Bar ── -->
        <materialDesign:Card Grid.Row="1" Padding="12" Margin="0,0,0,12">
            <WrapPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="{Binding IsSpoofing, Converter={StaticResource BooleanToIconConverter}}"
                                          Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"
                                          Foreground="{Binding IsSpoofing, Converter={StaticResource BooleanToBrushConverter}}"/>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock VerticalAlignment="Center" Margin="0,0,24,0">
                    <Run Text="已发送: "/><Run Text="{Binding PacketsSent}"/>
                </TextBlock>
                <TextBlock VerticalAlignment="Center">
                    <Run Text="最后发送: "/><Run Text="{Binding LastSentAt}"/>
                </TextBlock>
            </WrapPanel>
        </materialDesign:Card>

        <!-- ── Log Panel ── -->
        <materialDesign:Card Grid.Row="2" Padding="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="操作日志"
                           Style="{StaticResource MaterialDesignOverlineTextBlock}"
                           Margin="0,0,0,4"/>
                <ListBox ItemsSource="{Binding LogLines}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="11"
                         Background="Transparent" BorderThickness="0"/>
            </DockPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
