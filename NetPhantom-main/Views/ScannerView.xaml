<UserControl x:Class="NetPhantom.Views.ScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:NetPhantom.ViewModels">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <materialDesign:Card Grid.Row="0" Padding="16" Margin="0,0,0,12">
            <WrapPanel Orientation="Horizontal">

                <ComboBox Width="260" Margin="0,0,12,0"
                          materialDesign:HintAssist.Hint="选择网卡"
                          ItemsSource="{Binding Interfaces}"
                          SelectedItem="{Binding SelectedInterface}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                <TextBox Width="200" Margin="0,0,12,0"
                         materialDesign:HintAssist.Hint="扫描范围 (CIDR / 范围)"
                         Text="{Binding ScanRange, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <ToggleButton Margin="0,0,12,0"
                              IsChecked="{Binding UseArpScan}"
                              ToolTip="ARP 扫描 (快速) / Ping 扫描 (可靠)">
                    <ToggleButton.Content>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Radar" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding UseArpScan, StringFormat='{}ARP={0}'}"
                                       Margin="4,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton.Content>
                </ToggleButton>

                <Button Margin="0,0,8,0" Command="{Binding StartScanCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PlayCircle" Width="18" Height="18" VerticalAlignment="Center"/>
                        <TextBlock Text="开始扫描" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding CancelScanCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        IsEnabled="{Binding IsScanning}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="StopCircle" Width="18" Height="18" VerticalAlignment="Center"/>
                        <TextBlock Text="取消" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
        </materialDesign:Card>

        <!-- ── Status bar ── -->
        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="{Binding StatusText}"
                       VerticalAlignment="Center" Opacity="0.7"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}"/>
            <ProgressBar Value="{Binding ProgressValue}" Maximum="100"
                         IsIndeterminate="{Binding IsScanning}"
                         Margin="12,0,0,0" Height="4"
                         Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </DockPanel>

        <!-- ── Results DataGrid ── -->
        <materialDesign:Card Grid.Row="2" Margin="0,0,0,12">
            <DataGrid ItemsSource="{Binding Hosts}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="8 4 8 4"
                      SelectionMode="Single">

                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick"
                                  Command="{Binding SelectHostCommand}"
                                  CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=SelectedItem}"/>
                </DataGrid.InputBindings>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="IP 地址"   Binding="{Binding IpAddress}"    Width="140"/>
                    <DataGridTextColumn Header="MAC 地址"  Binding="{Binding MacAddress}"   Width="160"/>
                    <DataGridTextColumn Header="厂商"      Binding="{Binding Vendor}"       Width="180"/>
                    <DataGridTextColumn Header="主机名"    Binding="{Binding HostName}"     Width="200"/>
                    <DataGridTextColumn Header="响应时间 (ms)" Binding="{Binding ResponseTimeMs}" Width="120"/>
                </DataGrid.Columns>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                        <Setter Property="ToolTip" Value="双击填充到 ARP 欺骗页面"/>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </materialDesign:Card>

        <!-- ── Log Panel ── -->
        <materialDesign:Card Grid.Row="3" Padding="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="操作日志"
                           Style="{StaticResource MaterialDesignOverlineTextBlock}"
                           Margin="0,0,0,4"/>
                <ListBox ItemsSource="{Binding LogLines}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="11"
                         Background="Transparent" BorderThickness="0"/>
            </DockPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
